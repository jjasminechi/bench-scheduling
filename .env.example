# Copy this file to .env and fill in your keys.
# The harness runs in mock-cloud mode if no cloud key is set.

# Google Cloud / Gemini on Vertex AI (uses gcloud ADC — run: gcloud auth application-default login)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash
