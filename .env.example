# Copy to .env and fill in values.
# The harness mocks the cloud model (returns "A" for every question) when
# GOOGLE_CLOUD_PROJECT is not set — safe to run offline for local-only benchmarks.

# --- Vertex AI (Gemini) ---
# Run: gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash

# --- Local cost estimate ---
# Set to your actual electricity rate from your utility bill.
# Used only for local $ cost = energy_kwh * rate.  Default: 0.12 USD/kWh.
ELECTRICITY_RATE_USD_PER_KWH=0.12
