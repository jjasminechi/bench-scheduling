# Copy this file to .env and fill in your values.
# The harness mocks the cloud model when GOOGLE_CLOUD_PROJECT is not set.

# Vertex AI — run: gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash

# Your electricity rate from your utility bill (used for local $ cost)
# Default if unset: 0.12 USD/kWh  — override with your actual rate
ELECTRICITY_RATE_USD_PER_KWH=0.12

# Optional: Ollama host if not localhost
# OLLAMA_HOST=http://localhost:11434
